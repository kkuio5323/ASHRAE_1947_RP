EnergyManagementSystem:Program,
    pacu_vav_bot_MAX_OA_FRAC,    !- Name
    IF pacu_vav_bot_OA > pacu_vav_bot_OA_VRP,    !- Program Line 1
    SET pacu_vav_bot_MAX_OA_FRAC = NULL,    !- Program Line 2
    ELSE,                     !- Program Line 3
    IF pacu_vav_bot_SUPPLY_FLOW > 0,    !- Program Line 4
    SET pacu_vav_bot_MAX_OA_FRAC =      0.9561 / pacu_vav_bot_SUPPLY_FLOW,    !- Program Line 5
    ELSE,                     !- Program Line 6
    SET pacu_vav_bot_MAX_OA_FRAC = NULL,    !- Program Line 7
    ENDIF,                    !- Program Line 8
    ENDIF;                    !- Program Line 9

EnergyManagementSystem:Program,
    pacu_vav_mid_MAX_OA_FRAC,    !- Name
    IF pacu_vav_mid_OA > pacu_vav_mid_OA_VRP,    !- Program Line 1
    SET pacu_vav_mid_MAX_OA_FRAC = NULL,    !- Program Line 2
    ELSE,                     !- Program Line 3
    IF pacu_vav_mid_SUPPLY_FLOW > 0,    !- Program Line 4
    SET pacu_vav_mid_MAX_OA_FRAC =      0.9561 / pacu_vav_mid_SUPPLY_FLOW,    !- Program Line 5
    ELSE,                     !- Program Line 6
    SET pacu_vav_mid_MAX_OA_FRAC = NULL,    !- Program Line 7
    ENDIF,                    !- Program Line 8
    ENDIF;                    !- Program Line 9

EnergyManagementSystem:Program,
    pacu_vav_top_MAX_OA_FRAC,    !- Name
    IF pacu_vav_top_OA > pacu_vav_top_OA_VRP,    !- Program Line 1
    SET pacu_vav_top_MAX_OA_FRAC = NULL,    !- Program Line 2
    ELSE,                     !- Program Line 3
    IF pacu_vav_top_SUPPLY_FLOW > 0,    !- Program Line 4
    SET pacu_vav_top_MAX_OA_FRAC =      0.9561 / pacu_vav_top_SUPPLY_FLOW,    !- Program Line 5
    ELSE,                     !- Program Line 6
    SET pacu_vav_top_MAX_OA_FRAC = NULL,    !- Program Line 7
    ENDIF,                    !- Program Line 8
    ENDIF;                    !- Program Line 9

EnergyManagementSystem:Program,
    OA_BASED_OPTIMUM_START_EMS_Program,    !- Name
    IF DaylightSavings==0 && DayOfWeek>1 && Hour==5 && OAT<23.9 && OAT>1.7,    !- Program Line 1
    SET CLGSETP_SCH_Actuator = 26.7,    !- Program Line 2
    SET HTGSETP_SCH_Actuator = 15.6,    !- Program Line 3
    SET CLGSETP_SCH_w_SB_Actuator = 26.7,    !- Program Line 4
    SET HTGSETP_SCH_w_SB_Actuator = 15.6,    !- Program Line 5
    ELSEIF DaylightSavings==1 && DayOfWeek>1 && Hour==4 && OAT<23.9 && OAT>1.7,    !- Program Line 6
    SET CLGSETP_SCH_Actuator = 26.7,    !- Program Line 7
    SET HTGSETP_SCH_Actuator = 15.6,    !- Program Line 8
    SET CLGSETP_SCH_w_SB_Actuator = 26.7,    !- Program Line 9
    SET HTGSETP_SCH_w_SB_Actuator = 15.6,    !- Program Line 10
    ELSE,                     !- Program Line 11
    SET CLGSETP_SCH_Actuator = NULL,    !- Program Line 12
    SET HTGSETP_SCH_Actuator = NULL,    !- Program Line 13
    SET CLGSETP_SCH_w_SB_Actuator = NULL,    !- Program Line 14
    SET HTGSETP_SCH_w_SB_Actuator = NULL,    !- Program Line 15
    ENDIF;                    !- Program Line 16

