    OA_BASED_OPTIMUM_START_EMS_Program Manager,    !- Name
    BeginTimestepBeforePredictor,    !- EnergyPlus Model Calling Point
    OA_BASED_OPTIMUM_START_EMS_Program;    !- Program Name 1

EnergyManagementSystem:Program,
    Transformer_Load_Prog,    !- Name
    SET Wired_LTG = Facility_Int_LTG*0.0281;    !- Program Line 1

EnergyManagementSystem:Program,
    SET_Core_bottom_Light_EMS_Program,    !- Name
    SET Core_bottom_LSr_IP =0.093*Core_bottom_LSr/Core_bottom_Area,    !- Program Line 1
    IF (Core_bottom_Occ_Sensor <= 0) && (Core_bottom_LSr_IP >= 0.02),    !- Program Line 2
    SET Core_bottom_Light_Actuator = 0.02*Core_bottom_Area/0.09290304,    !- Program Line 3
    ELSE,                     !- Program Line 4
    SET Core_bottom_Light_Actuator = NULL,    !- Program Line 5
    ENDIF;                    !- Program Line 6

