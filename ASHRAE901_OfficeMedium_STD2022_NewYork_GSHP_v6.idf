EnergyManagementSystem:Program,
    SET_Perimeter_mid_ZN_2_Light_EMS_Program,    !- Name
    SET Perimeter_mid_ZN_2_LSr_IP =0.093*Perimeter_mid_ZN_2_LSr/Perimeter_mid_ZN_2_Area,    !- Program Line 1
    IF (Perimeter_mid_ZN_2_Occ_Sensor <= 0) && (Perimeter_mid_ZN_2_LSr_IP >= 0.02),    !- Program Line 2
    IF (DaylightSavings==0) && ((Hour < 7) || (Hour > 16)),    !- Program Line 3
    SET Perimeter_mid_ZN_2_Light_Actuator = 0.02*Perimeter_mid_ZN_2_Area/0.09290304,    !- Program Line 4
    ELSEIF (DaylightSavings==1) && ((Hour < 6) || (Hour > 15)),    !- Program Line 5
    SET Perimeter_mid_ZN_2_Light_Actuator = 0.02*Perimeter_mid_ZN_2_Area/0.09290304,    !- Program Line 6
    ELSE,                     !- Program Line 7
    SET Perimeter_mid_ZN_2_Light_Actuator = NULL,    !- Program Line 8
    ENDIF,                    !- Program Line 9
    ELSE,                     !- Program Line 10
    SET Perimeter_mid_ZN_2_Light_Actuator = NULL,    !- Program Line 11
    ENDIF;                    !- Program Line 12

