    SET Perimeter_mid_ZN_3_LSr_IP =0.093*Perimeter_mid_ZN_3_LSr/Perimeter_mid_ZN_3_Area,    !- Program Line 1
    IF (Perimeter_mid_ZN_3_Occ_Sensor <= 0) && (Perimeter_mid_ZN_3_LSr_IP >= 0.02),    !- Program Line 2
    SET Perimeter_mid_ZN_3_Light_Actuator = 0.02*Perimeter_mid_ZN_3_Area/0.09290304,    !- Program Line 3
    ELSE,                     !- Program Line 4
